{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "satori-digital/acf-field",
  "version": "1.0.0",
  "title": "ACF Field",
  "category": "theme",
  "icon": "admin-generic",
  "description": "Output an ACF field for the current post. Use inside Query Loop to display field data in patterns.",
  "supports": {
    "html": false,
    "color": {
      "text": true,
      "background": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true,
      "textAlign": true
    }
  },
  "attributes": {
    "fieldKey": {
      "type": "string",
      "default": ""
    }
  },
  "usesContext": ["postId", "postType"],
  "textdomain": "satori-acf-field-loop",
  "editorScript": "file:./build/index.js",
  "editorStyle": "file:./build/style-index.css"
}
